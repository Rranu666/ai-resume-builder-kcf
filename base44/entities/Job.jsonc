{
  "name": "Job",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Job title"
    },
    "company": {
      "type": "string",
      "description": "Company name"
    },
    "location": {
      "type": "string",
      "description": "Job location"
    },
    "type": {
      "type": "string",
      "enum": [
        "full-time",
        "part-time",
        "contract",
        "remote"
      ],
      "default": "full-time",
      "description": "Employment type"
    },
    "experience_level": {
      "type": "string",
      "enum": [
        "entry",
        "mid",
        "senior",
        "executive"
      ],
      "default": "mid",
      "description": "Required experience level"
    },
    "salary_min": {
      "type": "number",
      "description": "Minimum salary range"
    },
    "salary_max": {
      "type": "number",
      "description": "Maximum salary range"
    },
    "description": {
      "type": "string",
      "description": "Job description"
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required qualifications"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Required skills"
    },
    "benefits": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Job benefits"
    },
    "posted_date": {
      "type": "string",
      "format": "date",
      "description": "Date job was posted"
    },
    "application_deadline": {
      "type": "string",
      "format": "date",
      "description": "Application deadline"
    },
    "company_logo": {
      "type": "string",
      "description": "Company logo URL"
    },
    "is_trending": {
      "type": "boolean",
      "default": false,
      "description": "Whether the job is trending"
    },
    "remote_friendly": {
      "type": "boolean",
      "default": false,
      "description": "Whether remote work is allowed"
    }
  },
  "required": [
    "title",
    "company",
    "location",
    "description"
  ],
  "rls": {
    "read": {},
    "write": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}